      <aliases enabled='yes' />
      <column caption='Delivery status' datatype='string' name='[Calculation_1158671155896320]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min] &lt;= 30 THEN &apos;fast&apos; ELSE &apos;delayed&apos; END' />
      </column>
      <column caption='Revenue' datatype='integer' name='[Calculation_1158671160139777]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Quantity] * [Unit_Price]' />
      </column>
      <column caption='profit' datatype='real' name='[Calculation_1158671160565762]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1158671160139777] - [Cost]' />
      </column>
      <column caption='Profit status' datatype='string' name='[Calculation_1158671160709123]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1158671160565762] &lt; 0 THEN &quot;Loss&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Product Rank' datatype='integer' name='[Calculation_1158671162798085]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(sum([Calculation_1158671160139777]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top N filter' datatype='boolean' name='[Calculation_1158671163080710]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_1158671160139777])) &lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='City avg revenue' datatype='real' name='[Calculation_1158671163707399]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [City] : AVG([Calculation_1158671160139777]) }' />
